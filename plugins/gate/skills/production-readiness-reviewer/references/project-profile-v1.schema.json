{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:solo-suite:project-profile-v1",
  "title": "Solo Suite project profile v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema", "run_id", "project", "commit_sha", "environment", "profile",
    "timestamp", "categories"
  ],
  "properties": {
    "schema": {"const": "solo-suite/project-profile-v1"},
    "run_id": {
      "type": "string",
      "pattern": "^[a-z0-9](?:[a-z0-9._-]{1,62}[a-z0-9])$"
    },
    "project": {"type": "string", "minLength": 1},
    "commit_sha": {"type": "string", "pattern": "^[0-9a-fA-F]{7,64}$"},
    "environment": {"type": "string", "minLength": 1},
    "profile": {
      "enum": [
        "public-marketing-site", "saas-application", "e-commerce",
        "internal-application", "api-service", "library-package"
      ]
    },
    "timestamp": {"type": "string", "format": "date-time"},
    "categories": {
      "type": "array",
      "minItems": 14,
      "maxItems": 14,
      "items": {"$ref": "#/$defs/categoryApplicability"}
    }
  },
  "$defs": {
    "categoryApplicability": {
      "type": "object",
      "additionalProperties": false,
      "required": ["category", "applicability"],
      "properties": {
        "category": {
          "enum": [
            "Product", "Architecture", "Design", "Frontend", "Backend",
            "Database", "Security", "Testing", "Performance", "SEO",
            "Analytics", "Deployment", "Monitoring", "Documentation"
          ]
        },
        "applicability": {"enum": ["applicable", "not-applicable"]},
        "reason": {"type": "string", "minLength": 1}
      },
      "allOf": [
        {
          "if": {
            "properties": {"applicability": {"const": "not-applicable"}},
            "required": ["applicability"]
          },
          "then": {"required": ["reason"]}
        }
      ]
    }
  }
}
