{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:solo-suite:phase-gate-evidence-v1",
  "title": "Solo Suite phase gate evidence v1",
  "description": "Fail-closed GO/NO-GO evidence for before-code, before-merge, and before-deploy gates.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "room_digest",
    "run_id",
    "gate_id",
    "project",
    "commit_sha",
    "environment",
    "timestamp",
    "expires_at",
    "reviewer",
    "decision",
    "checks",
    "blockers"
  ],
  "properties": {
    "schema": {"const": "solo-suite/phase-gate-evidence-v1"},
    "room_digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "run_id": {
      "type": "string",
      "pattern": "^[a-z0-9](?:[a-z0-9._-]{1,62}[a-z0-9])$"
    },
    "gate_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]{1,63}$"
    },
    "project": {"type": "string", "minLength": 1},
    "commit_sha": {"type": "string", "pattern": "^[0-9a-fA-F]{7,64}$"},
    "environment": {"type": "string", "minLength": 1},
    "timestamp": {"type": "string", "format": "date-time"},
    "expires_at": {"type": "string", "format": "date-time"},
    "reviewer": {"type": "string", "minLength": 1},
    "decision": {"enum": ["GO", "NO-GO"]},
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/check"}
    },
    "blockers": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {"decision": {"const": "GO"}},
        "required": ["decision"]
      },
      "then": {
        "properties": {
          "blockers": {"maxItems": 0},
          "checks": {
            "items": {
              "properties": {"status": {"const": "PASS"}}
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {"decision": {"const": "NO-GO"}},
        "required": ["decision"]
      },
      "then": {
        "properties": {"blockers": {"minItems": 1}}
      }
    }
  ],
  "$defs": {
    "check": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "category",
        "run_id",
        "gate_id",
        "status",
        "commands_executed",
        "exit_code",
        "evidence_artifact",
        "artifact_digest"
      ],
      "properties": {
        "category": {"type": "string", "minLength": 1},
        "run_id": {
          "type": "string",
          "pattern": "^[a-z0-9](?:[a-z0-9._-]{1,62}[a-z0-9])$"
        },
        "gate_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]{1,63}$"
        },
        "status": {"enum": ["PASS", "FAIL"]},
        "commands_executed": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^\\$[a-z][a-z0-9-]*$"
          }
        },
        "exit_code": {"type": "integer"},
        "evidence_artifact": {"type": "string", "minLength": 1},
        "artifact_digest": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        }
      }
    }
  }
}
