        "$gate-production-ready"
      ],
      "deliverable": "One of BLOCKED, SAFE WITH WARNINGS, or SAFE TO LAUNCH.",
      "handoff_to": null,
      "handoff_check": "$ai-handoff-check",
      "task_ids": []
    }
