        "artifacts/production-release/categories/design.json",
        "artifacts/production-release/categories/documentation.json",
        "artifacts/production-release/categories/frontend.json",
        "artifacts/production-release/categories/monitoring.json",
        "artifacts/production-release/categories/performance.json",
        "artifacts/production-release/categories/product.json",
        "artifacts/production-release/categories/security.json",
        "artifacts/production-release/categories/seo.json",
        "artifacts/production-release/categories/testing.json",
        "artifacts/production-release/project-profile.json"
      ],
      "proposals": [
        ".solo/decisions.md",
        ".solo/handoff.md",
        ".solo/risks.md",
        ".solo/stack.md",
        ".solo/tasks.md"
      ],
