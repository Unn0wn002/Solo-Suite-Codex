  "gates": [
    {
      "id": "before_deploy",
      "command": "$gate-before-deploy",
      "stage": "before_deploy",
      "seat": "before_deploy_gatekeeper",
      "prerequisites": [
        {
          "category": "Release plan",
          "artifact": "artifacts/production-release/release-plan.json",
          "producer_commands": [
            "$release-deploy-plan",
            "$release-preflight",
            "$release-rollback-plan"
          ]
        },
        {
          "category": "Rollback",
          "artifact": "artifacts/production-release/rollback.json",
          "producer_commands": [
            "$release-deploy-plan",
            "$release-preflight",
            "$release-rollback-plan"
          ]
        },
        {
          "category": "Release documentation",
          "artifact": "artifacts/production-release/release-docs.json",
          "producer_commands": [
            "$docs-runbook",
            "$docs-update",
            "$git-release-notes"
          ]
        },
        {
          "category": "Security",
          "artifact": "artifacts/production-release/categories/security.json",
          "producer_commands": [
            "$gate-score-project",
            "$stack-intake"
          ]
        },
        {
          "category": "Testing",
          "artifact": "artifacts/production-release/categories/testing.json",
          "producer_commands": [
            "$gate-score-project",
            "$stack-intake"
          ]
        },
        {
          "category": "Deployment",
          "artifact": "artifacts/production-release/categories/deployment.json",
          "producer_commands": [
            "$gate-score-project",
            "$stack-intake"
          ]
        },
        {
          "category": "Monitoring",
          "artifact": "artifacts/production-release/categories/monitoring.json",
          "producer_commands": [
            "$gate-score-project",
            "$stack-intake"
          ]
        }
      ],
      "evidence": {
        "artifact": "artifacts/gates/production-release-before-deploy.json",
        "schema": "solo-suite/phase-gate-evidence-v1",
        "required_fields": [
          "schema",
          "room_digest",
          "run_id",
          "gate_id",
          "project",
          "commit_sha",
          "environment",
          "timestamp",
          "expires_at",
          "reviewer",
          "decision",
          "checks",
          "blockers"
        ],
        "freshness": {
          "run_id": "exact",
          "commit": "exact",
          "environment": "exact",
          "max_age_hours": 12
        }
      },
      "transitions": {
        "status_field": "decision",
        "routes": [
          {
            "statuses": [
              "GO"
            ],
            "next_stage": "production_gate"
          },
          {
            "statuses": [
              "NO-GO"
            ],
            "action": "stop"
          }
        ],
        "default_action": "stop"
      }
    },
    {
      "id": "production",
      "command": "$gate-production-ready",
      "stage": "production_gate",
      "seat": "production_gatekeeper",
      "prerequisites": [
        {
          "category": "Product",
          "artifact": "artifacts/production-release/categories/product.json",
          "producer_commands": [
            "$gate-score-project",
            "$stack-intake"
          ]
        },
        {
          "category": "Architecture",
