          "artifact": "artifacts/production-release/categories/frontend.json",
          "producer_commands": [
            "$gate-score-project",
            "$stack-intake"
          ]
        },
        {
          "category": "Backend",
          "artifact": "artifacts/production-release/categories/backend.json",
          "producer_commands": [
            "$gate-score-project",
            "$stack-intake"
          ]
        },
        {
          "category": "Database",
          "artifact": "artifacts/production-release/categories/database.json",
          "producer_commands": [
            "$gate-score-project",
            "$stack-intake"
          ]
        },
        {
          "category": "Security",
          "artifact": "artifacts/production-release/categories/security.json",
          "producer_commands": [
            "$gate-score-project",
            "$stack-intake"
          ]
        },
        {
          "category": "Testing",
          "artifact": "artifacts/production-release/categories/testing.json",
          "producer_commands": [
            "$gate-score-project",
            "$stack-intake"
          ]
        },
        {
          "category": "Performance",
          "artifact": "artifacts/production-release/categories/performance.json",
          "producer_commands": [
            "$gate-score-project",
            "$stack-intake"
          ]
        },
        {
          "category": "SEO",
          "artifact": "artifacts/production-release/categories/seo.json",
          "producer_commands": [
            "$gate-score-project",
            "$stack-intake"
          ]
        },
        {
          "category": "Analytics",
          "artifact": "artifacts/production-release/categories/analytics.json",
          "producer_commands": [
            "$gate-score-project",
            "$stack-intake"
          ]
        },
        {
          "category": "Deployment",
          "artifact": "artifacts/production-release/categories/deployment.json",
          "producer_commands": [
            "$gate-score-project",
            "$stack-intake"
          ]
        },
        {
          "category": "Monitoring",
          "artifact": "artifacts/production-release/categories/monitoring.json",
          "producer_commands": [
            "$gate-score-project",
            "$stack-intake"
          ]
        },
        {
          "category": "Documentation",
          "artifact": "artifacts/production-release/categories/documentation.json",
          "producer_commands": [
            "$gate-score-project",
            "$stack-intake"
          ]
